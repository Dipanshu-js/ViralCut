# ─── Database (Neon PostgreSQL recommended for Vercel) ────────────────────────
# Get free DB at: https://neon.tech
DATABASE_URL="postgresql://username:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"

# ─── Admin Account (auto-created on first login) ──────────────────────────────
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="your-secure-admin-password"

# ─── App URL (set to your Vercel deployment URL) ──────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ─── Groq AI (PRIMARY - FREE) ────────────────────────────────────────────────
# Get free key at: https://console.groq.com/keys
# Free tier: 14,400 requests/day
GROQ_API_KEY="gsk_your_groq_key_here"
# Optional: Add more keys for rotation under load
# GROQ_API_KEY_2="gsk_your_second_key"
# GROQ_API_KEY_3="gsk_your_third_key"
# GROQ_API_KEY_4="gsk_your_fourth_key"

# ─── YouTube Data API (for Trend Research) ───────────────────────────────────
# Get at: https://console.cloud.google.com/apis/library/youtube.googleapis.com
# Free: 10,000 units/day
YOUTUBE_API_KEY="AIza_your_youtube_api_key"

# ─── ElevenLabs (Voice TTS - Optional) ───────────────────────────────────────
# Get at: https://elevenlabs.io/app/speech-synthesis
# Falls back to Google TTS (free) if not set
ELEVENLABS_API_KEY="sk_your_elevenlabs_key"

# ─── Google Gemini (AI Fallback - Optional) ───────────────────────────────────
# Get at: https://aistudio.google.com/app/apikey
# Used as fallback when all Groq keys are rate-limited
GEMINI_API_KEY="AIza_your_gemini_key"

# ─── Premium Video Generation APIs (Optional) ─────────────────────────────────
# xAI / Grok - https://console.x.ai/
XAI_API_KEY="xai_your_key"

# Runway ML - https://app.runwayml.com/account
RUNWAY_API_KEY="key_your_runway_key"

# Luma Dream Machine - https://lumalabs.ai/dream-machine/api
LUMA_API_KEY="your_luma_key"

# Pika Labs - https://pika.art/
PIKA_API_KEY="your_pika_key"

# ─── Free Stock Video APIs (Optional but recommended) ─────────────────────────
# Pexels (free 200 req/hr) - https://www.pexels.com/api/
PEXELS_API_KEY="your_pexels_key"

# Pixabay (free) - https://pixabay.com/api/docs/
PIXABAY_API_KEY="your_pixabay_key"
